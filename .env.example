# =============================================================================
# SENVIROX — Host-ready environment
# Prefer: node scripts/generate-secrets.mjs app.yourdomain.com
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info
IMAGE_TAG=latest

# Public URLs (must match your TLS hostname)
NEXT_PUBLIC_APP_NAME=SENVIROX
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
NEXT_PUBLIC_API_URL=https://app.yourdomain.com/api/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# API
PORT=5000
HOST=0.0.0.0
API_PREFIX=/api/v1
CORS_ORIGIN=https://app.yourdomain.com

# User persistence: file (default self-host) | supabase | auto | memory(test only)
USER_STORE=file
DATA_DIR=/data

# Supabase (required only when USER_STORE=supabase or auto with credentials)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth secrets — generate with openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=senvirox
JWT_AUDIENCE=senvirox-api

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
DEVICE_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=30

# Redis (compose injects password into REDIS_URL)
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=senvirox:

# Protect GET /metrics (required in production)
METRICS_TOKEN=

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
